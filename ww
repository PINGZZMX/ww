        local predictionValue = tonumber(PredictionBox.Text) or 0
        predictionValue = math.clamp(predictionValue, 0, 10) 

        local smoothnessValue = tonumber(SmoothnessBox.Text) or 0
        smoothnessValue = math.clamp(smoothnessValue, 0, 10) 

        AimbotEnvironment.FOVCircle.Position = UserInputService:GetMouseLocation()
        AimbotEnvironment.FOVCircle.Visible = AimbotEnvironment.FOVSettings.Visible

        if AimbotEnabled then
            if AimbotEnvironment.Locked then
                local targetPart = AimbotEnvironment.Locked.Character:FindFirstChild(AimbotEnvironment.Settings.LockPart)
                if targetPart then
                    local targetPosition = targetPart.Position + (targetPart.AssemblyLinearVelocity * predictionValue) 
                    if AimbotEnvironment.Settings.ThirdPerson then
                        local currentMousePos = UserInputService:GetMouseLocation()
                        local targetScreenPos = Camera:WorldToViewportPoint(targetPosition)
                        local deltaX = (targetScreenPos.X - currentMousePos.X) * (smoothnessValue / 10) 
                        local deltaY = (targetScreenPos.Y - currentMousePos.Y) * (smoothnessValue / 10) 
                        mousemoverel(deltaX, deltaY)
                    else
                        Camera.CFrame = CFramenew(Camera.CFrame.Position, targetPosition)
                    end

                    AimbotEnvironment.FOVCircle.Color = AimbotEnvironment.FOVSettings.LockedColor
                end
            else
                AimbotEnvironment.FOVCircle.Color = AimbotEnvironment.FOVSettings.Color
            end
        else
            AimbotEnvironment.FOVCircle.Visible = false 
        end
    end)

